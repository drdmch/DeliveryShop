@{
    ViewData["Title"] = "Мої замовлення";
}

<div class="container mt-5" style="max-width: 500px;">
    <div class="card p-4 border-0 shadow-sm rounded-4 bg-white text-center">
        <div class="mb-3">
            <i class="bi bi-box-seam text-success" style="font-size: 3.5rem; color: var(--primary-green) !important;"></i>
        </div>
        <h3 class="mb-2" style="font-weight: 700;">Історія замовлень</h3>
        <p class="text-muted small mb-4">Введіть номер телефону або Email, який ви вказали під час оформлення доставки, щоб переглянути статус та залишити відгуки.</p>

        <form asp-action="SearchOrders" method="post">
            <div class="mb-3">
                <input type="text" name="searchKey" class="form-control text-center py-2" placeholder="+380... або example@gmail.com" required style="border-radius: 10px;" />
            </div>
            <button type="submit" class="btn btn-success w-100 py-2" style="background-color: var(--primary-green); border: none; font-weight: 600; border-radius: 10px;">
                Показати мої замовлення
            </button>
        </form>
    </div>
</div>