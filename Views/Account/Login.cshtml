@{
    ViewData["Title"] = "Вхід до системи";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
                <div class="text-center mb-4">
                    <h2 class="fw-bold m-0" style="color: var(--dark-text);"><i class="bi bi-box-arrow-in-right me-2" style="color: var(--primary-green);"></i>Вхід</h2>
                    <p class="text-muted small mt-1">Увійдіть у свій профіль Farmix</p>
                </div>
                
                <form asp-action="Login" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 fw-bold"></div>
                    
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary">Email адреса</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0" style="border-radius: 10px 0 0 10px;"><i class="bi bi-envelope text-muted"></i></span>
                            <input type="email" name="email" class="form-control bg-light border-start-0 py-2" placeholder="example@mail.com" style="border-radius: 0 10px 10px 0;" required />
                        </div>
                    </div>
                    
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-secondary">Пароль</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0" style="border-radius: 10px 0 0 10px;"><i class="bi bi-lock text-muted"></i></span>
                            <input type="password" name="password" class="form-control bg-light border-start-0 py-2" placeholder="Введіть пароль" style="border-radius: 0 10px 10px 0;" required />
                        </div>
                    </div>
                    
                    <button type="submit" class="btn btn-success w-100 py-2 shadow-sm fw-bold mb-3" style="background-color: var(--primary-green); border: none; border-radius: 10px;">
                        Увійти
                    </button>

                    <div class="text-center">
                        <span class="text-muted small">Ще немає акаунту?</span>
                        <a asp-action="Register" class="small fw-bold text-decoration-none ms-1" style="color: var(--primary-green);">Зареєструватися</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>