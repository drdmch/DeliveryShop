@{
    ViewData["Title"] = "Оформлення замовлення";
}

<div class="container mt-4" style="max-width: 600px;">
    <h2 class="mb-4" style="color: var(--dark-text); font-weight: bold;"><i class="bi bi-truck me-2"></i> Контактні дані доставки</h2>

    <div class="card shadow-sm border-0 rounded-4 p-4 bg-white">
        <form asp-action="SubmitOrder" method="post">
            <div class="row mb-3">
                <div class="col">
                    <label class="form-label" style="font-weight: 500;">Ім'я</label>
                    <input type="text" name="firstName" class="form-value form-control" required />
                </div>
                <div class="col">
                    <label class="form-label" style="font-weight: 500;">Прізвище</label>
                    <input type="text" name="lastName" class="form-value form-control" required />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label" style="font-weight: 500;">Номер телефону</label>
                <input type="tel" name="phone" class="form-control" placeholder="+380" required />
            </div>

            <div class="mb-3">
                <label class="form-label" style="font-weight: 500;">Email</label>
                <input type="email" name="email" class="form-control" placeholder="example@gmail.com" required />
            </div>

            <div class="mb-3">
                <label class="form-label" style="font-weight: 500;">Адреса доставки</label>
                <input type="text" name="address" class="form-control" placeholder="Місто, вулиця, будинок, квартира" required />
            </div>

            <div class="mb-4">
                <label class="form-label" style="font-weight: 500;">Коментар до замовлення (необов'язково)</label>
                <textarea name="comment" class="form-control" rows="3"></textarea>
            </div>

            <div class="p-3 rounded-3 mb-4 text-center" style="background-color: var(--light-green); color: var(--dark-text); font-weight: bold; font-size: 1.15rem;">
                Сума до сплати: @ViewBag.TotalSum грн
            </div>

            <button type="submit" class="btn btn-success w-100 py-2 rounded-3" style="background-color: var(--primary-green); border: none; font-weight: 600;">
                Підтвердити замовлення
            </button>
        </form>
    </div>
</div>