@model DeliveryShopApp.Models.Product
@{
    ViewData["Title"] = Model.Name;
    double avgRating = ViewBag.AverageRating;
}

<div class="container mt-5">
    <div class="mb-4">
        <a asp-action="Index" class="text-decoration-none" style="color: var(--primary-green); font-weight: 500;">
            <i class="bi bi-arrow-left"></i> Назад до каталогу
        </a>
    </div>

    <div class="row g-5 mb-5">
        <div class="col-md-6">
            <div class="p-2 bg-white border rounded-4 shadow-sm">
                <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "https://placehold.co/600x450?text=No+Image" : Model.ImageUrl)" class="img-fluid rounded-4 w-100" alt="@Model.Name" style="max-height: 400px; object-fit: cover;" />
            </div>
        </div>

        <div class="col-md-6 d-flex flex-column">
            <div class="d-flex align-items-center gap-2 mb-2">
                <span class="badge" style="background-color: var(--light-green); color: var(--dark-text); font-size: 0.85rem; padding: 6px 12px; border-radius: 8px;">
                    @Model.Category?.Name
                </span>
                @if (avgRating > 0)
                {
                    <div class="rating-stars d-flex align-items-center bg-light px-2 py-1 rounded-2" style="font-size: 0.85rem;">
                        <i class="bi bi-star-fill text-warning"></i>
                        <span class="ms-1 fw-bold">@avgRating.ToString("F1")</span>
                        <span class="text-muted ms-1">(@Model.Reviews.Count)</span>
                    </div>
                }
            </div>
            
            <h1 class="mb-3" style="font-weight: 700; letter-spacing: -0.5px;">@Model.Name</h1>
            
            <div class="mb-4 flex-grow-1">
                <h6 class="text-muted text-uppercase" style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.5px;">Опис продукту</h6>
                <p class="text-secondary" style="line-height: 1.6; font-size: 1rem;">@Model.Description</p>
            </div>

            <div class="p-4 rounded-4 bg-white border shadow-sm">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <small class="text-muted d-block">Ціна за @Model.Unit?.Name</small>
                        <span style="font-size: 1.6rem; font-weight: bold; color: var(--primary-green);">@Model.Price грн</span>
                    </div>
                    @if (Model.IsAvailable && Model.StockQuantity > 0)
                    {
                        <span class="badge bg-success bg-opacity-10 text-success rounded-3 px-3 py-2">В наявності</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-3 px-3 py-2">Немає</span>
                    }
                </div>

                @if (Model.IsAvailable && Model.StockQuantity > 0)
                {
                    <form asp-controller="Cart" asp-action="AddToCart" method="post" class="row g-2 align-items-center">
                        <input type="hidden" name="productId" value="@Model.Id" />
                        <div class="col-4">
                            <input type="number" name="quantity" class="form-control text-center py-2" value="1" min="1" step="@(Model.Unit?.Name == "кг" ? "0.1" : "1")" onkeypress="@(Model.Unit?.Name == "шт" ? "return event.charCode >= 48 && event.charCode <= 57" : "")" style="font-weight: 600; border-radius: 8px;" />
                        </div>
                        <div class="col-8">
                            <button type="submit" class="btn btn-success w-100 py-2" style="background-color: var(--primary-green); border: none; font-weight: 600; border-radius: 8px;">
                                Додати у кошик
                            </button>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <h4 class="mb-4" style="font-weight: 700;"><i class="bi bi-chat-left-text me-2" style="color: var(--primary-green);"></i>Відгуки покупців (@Model.Reviews.Count)</h4>
            
            @if (!Model.Reviews.Any())
            {
                <p class="text-muted py-3 bg-light rounded-4 text-center">Будьте першим, хто залишить відгук на цей товар!</p>
            }
            else
            {
                <div class="d-flex flex-column gap-3 mb-4">
                    @foreach (var review in Model.Reviews.OrderByDescending(r => r.CreatedAt))
                    {
                        <div class="card border-0 shadow-sm p-3 rounded-4 bg-white">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <strong style="font-size: 0.95rem;">@review.AuthorName</strong>
                                <span class="text-muted" style="font-size: 0.75rem;">@review.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")</span>
                            </div>
                            <div class="rating-stars mb-2" style="font-size: 0.8rem; color: #ffc107;">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="bi @(i <= review.Rating ? "bi-star-fill" : "bi-star")"></i>
                                }
                            </div>
                            <p class="text-secondary mb-0" style="font-size: 0.9rem; line-height: 1.5;">@review.Comment</p>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>