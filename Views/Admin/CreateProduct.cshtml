@model DeliveryShopApp.Models.Product
@{
    ViewData["Title"] = "Додавання товару";
    var categories = ViewBag.Categories as List<DeliveryShopApp.Models.Category> ?? new List<DeliveryShopApp.Models.Category>();
    var units = ViewBag.Units as List<DeliveryShopApp.Models.Unit> ?? new List<DeliveryShopApp.Models.Unit>();
}

<div class="container mt-4" style="max-width: 600px;">
    <h2 class="fw-bold mb-4"><i class="bi bi-plus-circle text-success me-2"></i> Новий товар</h2>

    <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
        <form asp-action="CreateProduct" method="post">
            <div class="mb-3">
                <label class="form-label small fw-bold">Назва товару</label>
                <input type="text" name="Name" class="form-control" style="border-radius: 8px;" required />
            </div>

            <div class="row g-2 mb-3">
                <div class="col-md-6">
                    <label class="form-label small fw-bold">Категорія</label>
                    <select name="CategoryId" class="form-select" style="border-radius: 8px;" required>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small fw-bold">Одиниця виміру</label>
                    <select name="UnitId" class="form-select" style="border-radius: 8px;" required>
                        @foreach (var u in units)
                        {
                            <option value="@u.Id">@u.Name</option>
                        }
                    </select>
                </div>
            </div>

            <div class="row g-2 mb-3">
                <div class="col-md-6">
                    <label class="form-label small fw-bold">Ціна (грн)</label>
                    <input type="number" name="Price" class="form-control" step="0.01" min="0" style="border-radius: 8px;" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label small fw-bold">Кількість на складі</label>
                    <input type="number" name="StockQuantity" class="form-control" min="0" style="border-radius: 8px;" required />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label small fw-bold">Посилання на зображення URL</label>
                <input type="url" name="ImageUrl" class="form-control" style="border-radius: 8px;" />
            </div>

            <div class="mb-4">
                <label class="form-label small fw-bold">Опис товару</label>
                <textarea name="Description" class="form-control" rows="3" style="border-radius: 8px;"></textarea>
            </div>

            <div class="d-flex gap-2">
                <a asp-action="Products" class="btn btn-light w-50" style="border-radius: 8px;">Скасувати</a>
                <button type="submit" class="btn btn-success w-50" style="background-color: var(--primary-green); border: none; border-radius: 8px; font-weight: 600;">Зберегти</button>
            </div>
        </form>
    </div>
</div>