@model IEnumerable<DeliveryShopApp.Models.Order>
@{
    ViewData["Title"] = "Панель адміністратора";
    var statuses = ViewBag.Statuses as List<DeliveryShopApp.Models.OrderStatus> ?? new List<DeliveryShopApp.Models.OrderStatus>();
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Панель управління магазином</h2>
        <a asp-action="Products" class="btn btn-success" style="background-color: var(--primary-green); border: none; border-radius: 8px;">Керувати каталогом</a>
    </div>

    <div class="row g-3 mb-4 text-center">
        <div class="col-md-4">
            <div class="card p-3 border-0 shadow-sm rounded-4 bg-white">
                <h6 class="text-muted small text-uppercase">Всього товарів</h6>
                <h2 class="fw-bold m-0 text-success">@ViewBag.ProductsCount</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-3 border-0 shadow-sm rounded-4 bg-white">
                <h6 class="text-muted small text-uppercase">Замовлень у базі</h6>
                <h2 class="fw-bold m-0 text-primary">@ViewBag.OrdersCount</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-3 border-0 shadow-sm rounded-4 bg-white">
                <h6 class="text-muted small text-uppercase">Користувачів</h6>
                <h2 class="fw-bold m-0 text-dark">@ViewBag.UsersCount</h2>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 bg-white p-3">
        <h4 class="fw-bold mb-3">Історія та статуси замовлень</h4>
        <div class="table-responsive">
            <table class="table align-middle">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Клієнт</th>
                        <th>Адреса доставки</th>
                        <th>Сума</th>
                        <th>Поточний статус</th>
                        <th>Змінити статус</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td class="fw-bold">#@order.Id</td>
                            <td>@order.User?.FirstName @order.User?.LastName<br /><small class="text-muted">@order.User?.Phone</small></td>
                            <td>@order.DeliveryAddress</td>
                            <td class="fw-bold">@order.TotalPrice грн</td>
                            <td>
                                <span class="badge bg-success bg-opacity-10 text-success px-2 py-1">@order.CurrentStatus?.Name</span>
                            </td>
                            <td>
                                <form asp-action="UpdateOrderStatus" method="post" class="d-flex gap-2 m-0">
                                    <input type="hidden" name="orderId" value="@order.Id" />
                                    <select name="statusId" class="form-select form-select-sm" style="border-radius: 6px;">
                                        @foreach (var status in statuses)
                                        {
                                            <!option value="@status.Id" @(status.Id == order.CurrentStatusId ? "selected" : "")>@status.Name</!option>
                                        }
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-outline-success">Оновити</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>