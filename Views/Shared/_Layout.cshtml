<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Farmix</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DeliveryShopApp.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom shadow-sm mb-4">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index" style="color: var(--primary-green); font-weight: bold; font-size: 1.4rem;">
                    <i class="bi bi-shop me-2"></i> Farmix
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button> 
                
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav align-items-center gap-3">
                        @if (!User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-success bg-success bg-opacity-10 fw-bold px-3 d-inline-flex align-items-center" asp-controller="Orders" asp-action="Index" style="border-radius: 8px; border: 1px solid rgba(40, 167, 69, 0.2); white-space: nowrap;">
                                    <i class="bi bi-box-seam me-2"></i> Мої замовлення
                                </a>
                            </li>
                            <li class="nav-item">
                                <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-success d-flex align-items-center px-3" style="border-color: var(--primary-green); color: var(--primary-green); font-weight: 500; border-radius: 8px;">
                                    <i class="bi bi-cart3 me-2" style="font-size: 1.1rem;"></i> Кошик
                                </a>
                            </li>
                        }
                        
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item d-flex align-items-center gap-1 ms-2">
                                
                                @if (User.IsInRole("Admin"))
                                {
                                    <span class="badge bg-danger rounded-2 px-2 py-1 ms-1" style="font-size: 0.75rem;">Адмін</span>
                                    <a class="btn btn-sm btn-outline-danger ms-2" asp-controller="Admin" asp-action="Index" style="border-radius: 6px;">
                                        <i class="bi bi-speedometer2"></i> Панель
                                    </a>
                                    <a class="btn btn-sm btn-outline-dark ms-2" href="/products-api.html" style="border-radius: 6px;">
                                        <i class="bi bi-box"></i> Products API
                                    </a>
                                }
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-sm btn-light border px-3" asp-controller="Account" asp-action="Logout" style="border-radius: 8px; font-weight: 500;">
                                    <i class="bi bi-box-arrow-right me-1"></i> Вийти
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item ms-2">
                                <a class="nav-link text-dark fw-bold" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1 text-success"></i> Вхід
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-sm btn-success text-white px-3" asp-controller="Account" asp-action="Register" style="background-color: var(--primary-green); border: none; border-radius: 8px; font-weight: 500;">
                                    Реєстрація
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container flex-grow-1">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top text-muted bg-white py-3 mt-auto">
        <div class="container text-center text-sm-start">
            &copy; 2026 - DeliveryShopApp - <a asp-controller="Home" asp-action="Privacy" style="color: var(--primary-green);">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>